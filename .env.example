# SQLite for local dev; set to a PostgreSQL URL in production:
#   postgresql+asyncpg://user:password@host:5432/dbname
# Railway provides $DATABASE_URL automatically when a Postgres plugin is added.
DATABASE_URL=sqlite+aiosqlite:///data/grants.db
EMBEDDING_MODEL=all-MiniLM-L6-v2
MODEL_PATH=ml/model.pkl
FAISS_INDEX_PATH=data/grants.faiss
API_KEY=changeme
MAX_RESULTS=20
GtR_API_BASE=https://gtr.ukri.org/gtr/api
UKRI_OPPORTUNITIES_URL=https://www.ukri.org/opportunity/
